# Supabase — configuración del módulo @nuxtjs/supabase.
# Copia este archivo a `.env` y reemplaza con los valores reales de tu proyecto.
# NO subas `.env` al repositorio (ya está ignorado en .gitignore).

# URL del proyecto Supabase (ej: https://xxxxxxxxxxxx.supabase.co)
SUPABASE_URL=

# Clave pública (publishable / anon key). Segura para el cliente; respeta RLS.
SUPABASE_KEY=

# Clave de service role (server-only). Omite RLS: NUNCA exponer al cliente.
# El módulo más reciente la nombra SUPABASE_SECRET_KEY; SUPABASE_SERVICE_KEY
# sigue funcionando como alias en desuso. Usa una de las dos.
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_KEY=
