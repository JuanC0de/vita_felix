# Supabase — configuración del módulo @nuxtjs/supabase.
# Copia este archivo a `.env` y reemplaza con los valores reales de tu proyecto.
# NO subas `.env` al repositorio (ya está ignorado en .gitignore).

# URL del proyecto Supabase (ej: https://xxxxxxxxxxxx.supabase.co)
SUPABASE_URL=

# Clave pública (publishable / anon key). Segura para el cliente; respeta RLS.
SUPABASE_KEY=

# Clave de service role (server-only). Omite RLS: NUNCA exponer al cliente.
# El módulo más reciente la nombra SUPABASE_SECRET_KEY; SUPABASE_SERVICE_KEY
# sigue funcionando como alias en desuso. Usa una de las dos.
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_KEY=

# ─── Ticketing (server-only; NUNCA exponer al cliente) ───
# Secreto para firmar el JWT del QR (HMAC-SHA256). Cadena larga y aleatoria.
# Generar: openssl rand -base64 48
NUXT_QR_JWT_SECRET=

# Clave de cifrado de la cédula (AES-256-GCM). Exactamente 32 bytes en base64.
# Generar: openssl rand -base64 32
NUXT_ATTENDEE_ENC_KEY=

# Horas de gracia tras la fecha del evento durante las que el QR sigue válido.
NUXT_QR_GRACE_HOURS=12

# ─── E2E opcional (Playwright, flujo completo ticketing) ───
# E2E_GATE_EMAIL=gatestaff@vitafelix.local
# E2E_GATE_PASSWORD=ChangeMe123!
# E2E_PUBLISHED_EVENT_ID=<uuid de un evento en estado published>
